# Odyssey Studio — environment variables
#
# The standalone Sanity Studio runs on Vite and only exposes variables
# prefixed with SANITY_STUDIO_ to the browser.
# (NEXT_PUBLIC_* does NOT work here — that prefix is Next.js only.)
#
# Copy this file to apps/studio/.env and fill in the values.
# Use the same project ID and dataset as in the root .env.

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_TOKEN=
