# Odyssey Studio — omgevingsvariabelen
#
# De standalone Sanity Studio draait op Vite en exposes alleen
# variabelen met het SANITY_STUDIO_-prefix aan de browser.
# (NEXT_PUBLIC_* werkt hier NIET — dat is alleen voor Next.js.)
#
# Kopieer dit bestand naar apps/studio/.env en vul de waarden in.
# Dezelfde project ID en dataset als in de root .env.

SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
