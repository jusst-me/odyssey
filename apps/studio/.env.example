# Odyssey Studio — omgevingsvariabelen
# Kopieer de waarden uit de root .env (NEXT_PUBLIC_SANITY_*).
# De Studio leest dezelfde variabelen als de Next.js apps zodat er
# geen dubbele configuratie nodig is.
#
# Lokaal: zorg dat de root .env gevuld is — deze app pikt die
# automatisch op via Turborepo globalDependencies.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
