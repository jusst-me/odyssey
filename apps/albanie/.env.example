# --- Sanity (shared project/dataset, multi-market via `market` field) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-15
# Server-only token for draft/preview reads (do NOT prefix with NEXT_PUBLIC)
SANITY_API_READ_TOKEN=

# --- TradeTracker XML product feeds ---
# Comma-separated advertiser feed URLs (including feed id / credentials)
TRADETRACKER_FEED_URLS=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
