# ============================================================
# Odyssey — root environment example
# ------------------------------------------------------------
# Copy to `.env` at the repo root for values shared across the
# workspace (Turbo treats root `.env` as a global dependency).
# App-specific values live in each app, e.g.
# `apps/albanie/.env.local` (see apps/albanie/.env.example).
# NEVER commit real secrets — only this example is tracked.
# ============================================================

# --- Sanity (shared project/dataset, multi-market via `market` field) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-15
# Server-only token for draft/preview reads (do NOT prefix with NEXT_PUBLIC)
SANITY_API_READ_TOKEN=

# --- TradeTracker XML product feeds ---
# Comma-separated advertiser feed URLs (including feed id / credentials)
TRADETRACKER_FEED_URLS=

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Turborepo remote caching (Vercel) ---
# Optional locally (or run `pnpm exec turbo login && turbo link`). In CI these
# come from the TURBO_TOKEN secret + TURBO_TEAM variable. See docs/deployment.md.
TURBO_TOKEN=
TURBO_TEAM=
